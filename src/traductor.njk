---
layout: base.njk
title: "Traductor — Guía de Berlín"
permalink: /traductor/index.html
---

<div class="d-flex align-items-center justify-content-between mb-4">
  <h2 class="module-title mb-0">Mariano Traduce</h2>
</div>

{# ── Selector de modo ──────────────────────────────────────────────────── #}
<div class="d-flex gap-2 mb-4" id="modo-tabs">
  <button class="gallery-upload-btn" id="tab-texto" onclick="setModo('texto')">
    <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M0 0h1v15h15v1H0V0Zm14.817 3.113a.5.5 0 0 1 .07.704l-4.5 5.5a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61 4.15-5.073a.5.5 0 0 1 .704-.07z"/>
    </svg>
    Texto
  </button>
  <button class="gallery-action-btn gallery-cancel-btn" id="tab-imagen" onclick="setModo('imagen')">
    <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
      <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
    </svg>
    Foto
  </button>
</div>

{# ── Formulario ────────────────────────────────────────────────────────── #}
<div id="panel-texto">
  <textarea id="input-texto" class="trad-textarea" rows="5"
    placeholder="Escribe o pega texto en alemán…"></textarea>
</div>

<div id="panel-imagen" class="d-none">
  <label class="trad-img-label" id="img-label" for="input-imagen">
    <svg width="28" height="28" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
      <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
    </svg>
    <span id="img-label-text">Toca para seleccionar una foto (JPEG)</span>
  </label>
  <input type="file" id="input-imagen" accept="image/jpeg,image/jpg" class="d-none">
  <img id="img-preview" class="trad-img-preview d-none" alt="Vista previa">
</div>

<div class="mt-3 mb-3">
  <input type="text" id="input-contexto" class="trad-input-contexto"
    placeholder="Contexto (opcional): p.ej. «menú de restaurante», «señal de tráfico»…">
</div>

<button class="gallery-upload-btn" id="btn-traducir" onclick="traducir()" style="width:100%;justify-content:center;font-size:.95rem;padding:.7rem 1rem">
  Traducir
</button>

{# ── Estados ───────────────────────────────────────────────────────────── #}
<div id="trad-loading" class="d-none text-center py-4">
  <div class="spinner-border text-secondary" role="status" style="width:1.75rem;height:1.75rem"></div>
  <p class="mt-2 text-muted small">Consultando a Mariano…</p>
</div>

<div id="trad-error" class="d-none mt-3" role="alert"
  style="border:1px solid var(--rule);background:#fff9f7;color:#7a3523;border-radius:.65rem;padding:1rem;font-family:var(--font-sans);font-size:.9rem"></div>

{# ── Resultado ─────────────────────────────────────────────────────────── #}
<div id="trad-resultado" class="d-none mt-4">

  <div class="trad-block">
    <p class="trad-label">Original</p>
    <p id="res-original" class="trad-text"></p>
  </div>

  <div class="trad-block trad-block--traduccion">
    <p class="trad-label">Traducción</p>
    <p id="res-traduccion" class="trad-text trad-text--big"></p>
  </div>

  <div id="res-fragmentos-wrap" class="d-none">
    <p class="trad-label mt-3">Fragmento a fragmento</p>
    <table id="res-fragmentos" class="trad-table"></table>
  </div>

  <div id="res-notas-wrap" class="d-none trad-block">
    <p class="trad-label">Notas</p>
    <p id="res-notas" class="trad-text trad-text--muted"></p>
  </div>

  <div id="res-mariano-wrap" class="d-none trad-mariano">
    <span class="trad-mariano-ico">💬</span>
    <p id="res-mariano" class="trad-mariano-text"></p>
  </div>

</div>

<script>
const WORKER = 'https://mariano-traductor.victor-garcia-penyas.workers.dev';
const TOKEN  = '{{ workerToken }}';

let modo = 'texto';

function setModo(m) {
  modo = m;
  document.getElementById('panel-texto').classList.toggle('d-none', m !== 'texto');
  document.getElementById('panel-imagen').classList.toggle('d-none', m !== 'imagen');
  document.getElementById('tab-texto').className   = m === 'texto'   ? 'gallery-upload-btn' : 'gallery-action-btn gallery-cancel-btn';
  document.getElementById('tab-imagen').className  = m === 'imagen'  ? 'gallery-upload-btn' : 'gallery-action-btn gallery-cancel-btn';
}

// Preview de imagen
document.getElementById('input-imagen').addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file) return;
  const preview = document.getElementById('img-preview');
  const label   = document.getElementById('img-label-text');
  preview.src = URL.createObjectURL(file);
  preview.classList.remove('d-none');
  label.textContent = file.name;
});

async function traducir() {
  const btn = document.getElementById('btn-traducir');
  const contexto = document.getElementById('input-contexto').value.trim();

  ocultarResultado();
  document.getElementById('trad-error').classList.add('d-none');

  const fd = new FormData();
  if (modo === 'texto') {
    const txt = document.getElementById('input-texto').value.trim();
    if (!txt) { mostrarError('Escribe algo antes de traducir.'); return; }
    fd.append('text', txt);
  } else {
    const file = document.getElementById('input-imagen').files[0];
    if (!file) { mostrarError('Selecciona una foto antes de traducir.'); return; }
    fd.append('image', file);
  }
  if (contexto) fd.append('context', contexto);

  btn.disabled = true;
  document.getElementById('trad-loading').classList.remove('d-none');

  try {
    const r = await fetch(WORKER + '/translate', {
      method: 'POST',
      headers: { 'x-api-token': TOKEN },
      body: fd
    });
    const data = await r.json();
    if (!r.ok || !data.success) throw new Error(data.error || 'Error en el worker (' + r.status + ')');
    mostrarResultado(data.result);
  } catch (err) {
    mostrarError(err.message || 'Error de red. Comprueba la conexión.');
  } finally {
    btn.disabled = false;
    document.getElementById('trad-loading').classList.add('d-none');
  }
}

function mostrarResultado(res) {
  document.getElementById('res-original').textContent    = res.texto_original  || '';
  document.getElementById('res-traduccion').textContent  = res.texto_traducido || '';

  const fragWrap = document.getElementById('res-fragmentos-wrap');
  const fragTbl  = document.getElementById('res-fragmentos');
  if (res.fragmentos && res.fragmentos.length > 1) {
    fragTbl.innerHTML = res.fragmentos.map(f =>
      `<tr><td class="trad-frag-orig">${esc(f.original)}</td><td class="trad-frag-trad">${esc(f.traduccion)}</td></tr>`
    ).join('');
    fragWrap.classList.remove('d-none');
  } else {
    fragWrap.classList.add('d-none');
  }

  const notasWrap = document.getElementById('res-notas-wrap');
  if (res.notas) {
    document.getElementById('res-notas').textContent = res.notas;
    notasWrap.classList.remove('d-none');
  } else {
    notasWrap.classList.add('d-none');
  }

  const mWrap = document.getElementById('res-mariano-wrap');
  if (res.mariano) {
    document.getElementById('res-mariano').textContent = res.mariano;
    mWrap.classList.remove('d-none');
  } else {
    mWrap.classList.add('d-none');
  }

  document.getElementById('trad-resultado').classList.remove('d-none');
}

function ocultarResultado() {
  document.getElementById('trad-resultado').classList.add('d-none');
}

function mostrarError(msg) {
  const el = document.getElementById('trad-error');
  el.textContent = msg;
  el.classList.remove('d-none');
}

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
</script>
