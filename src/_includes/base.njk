<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "Guía de viaje" }}</title>
  <meta name="description" content="{{ description or 'Itinerario y paradas día a día' }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@400;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/styles.css' | url }}">
</head>

<body>
  <div class="site-shell">
    <header class="site-header">
      <div class="site-brand">
        <h1 class="site-title mb-0">
          <a href="{{ '/' | url }}" class="text-decoration-none">Guía de Berlín</a>
        </h1>
        <p class="site-tagline mb-0">Marzo 2026 · Itinerario · Historia · Recursos · Galería</p>
      </div>
      <nav class="site-nav" aria-label="Módulos">
        <a href="{{ '/' | url }}"{% if page.url == '/' %} class="active"{% endif %}>Guía</a>
        <a href="{{ '/historia/' | url }}"{% if '/historia/' in page.url %} class="active"{% endif %}>Historia</a>
        <a href="{{ '/recursos/' | url }}"{% if '/recursos/' in page.url %} class="active"{% endif %}>Recursos</a>
        <a href="{{ '/galeria/' | url }}"{% if '/galeria/' in page.url %} class="active"{% endif %}>Galería</a>
      </nav>
    </header>

    <main class="site-main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      © {{ build.year }} — Hecho con Eleventy
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
  // TTS — hace clicables las columnas "Alemán" en tablas de recursos_idioma
  (function () {
    var ICON = '<span class="tts-icon" aria-hidden="true"><svg width="10" height="11" viewBox="0 0 10 11" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><polygon points="0,0 10,5.5 0,11"/></svg></span>';

    document.querySelectorAll('table').forEach(function (table) {
      var headers = Array.from(table.querySelectorAll('thead th, tr:first-child th'));
      var idx = headers.findIndex(function (th) { return th.textContent.trim() === 'Alemán'; });
      if (idx === -1) return;
      table.querySelectorAll('tbody tr').forEach(function (row) {
        var td = row.querySelectorAll('td')[idx];
        if (!td) return;
        var text = td.textContent.trim();
        td.innerHTML = '<a href="#" class="tts-link" data-tts="' +
          text.replace(/&/g,'&amp;').replace(/"/g,'&quot;') +
          '">' + ICON + ' ' + td.innerHTML + '</a>';
      });
    });

    document.addEventListener('click', function (e) {
      var el = e.target.closest('[data-tts]');
      if (!el) return;
      e.preventDefault();
      if (!window.speechSynthesis) return;
      window.speechSynthesis.cancel();
      var utt = new SpeechSynthesisUtterance(el.dataset.tts);
      utt.lang = 'de-DE';
      utt.rate = 0.9;
      el.classList.add('tts-playing');
      utt.onend = function () { el.classList.remove('tts-playing'); };
      utt.onerror = function () { el.classList.remove('tts-playing'); };
      window.speechSynthesis.speak(utt);
    });
  })();
  </script>
</body>
</html>
